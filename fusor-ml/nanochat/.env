# Runtime-tunable nanochat synthetic stroke settings.

# The defaults use a much larger synthetic dataset while keeping runtime reasonable.
NANOCHAT_EPOCHS=100
NANOCHAT_WARMUP_STEPS=12
NANOCHAT_LEARNING_RATE=0.004
NANOCHAT_MIN_LEARNING_RATE=4e-4
NANOCHAT_BETA1=0.9
NANOCHAT_BETA2=0.95
NANOCHAT_ADAM_EPS=1e-8
NANOCHAT_WEIGHT_DECAY=0.01
NANOCHAT_LOG_EVERY=12
NANOCHAT_EVAL_BATCHES=2
NANOCHAT_BLOCK_SIZE=24
NANOCHAT_BATCH_SIZE=128
NANOCHAT_N_EMBD=48
NANOCHAT_N_HEAD=4
NANOCHAT_N_FF=48
NANOCHAT_N_LAYER=16
NANOCHAT_CONV_KERNEL_SIZE=3
NANOCHAT_ATTENTION_PERIOD=1
NANOCHAT_EPS=1e-5
NANOCHAT_INIT_SCALE=0.1
NANOCHAT_SEED=666
NANOCHAT_TRAIN_EXAMPLES=512
NANOCHAT_VALID_EXAMPLES=96
NANOCHAT_TEST_EXAMPLES=96
NANOCHAT_SAMPLE_PREFIX_TOKENS=4
NANOCHAT_SAMPLE_TOKENS=128
NANOCHAT_SAMPLE_TEMPERATURE=0.7
NANOCHAT_SAMPLE_TOP_K=4
NANOCHAT_SAVE_EVERY_STEPS=0
NANOCHAT_SAVE_FINAL_MODEL=true
NANOCHAT_SAVE_QUANTIZATION=q4_0
NANOCHAT_GGUF_PATH=nanochat.gguf
NANOCHAT_SAMPLE_OUTPUT_PATH=nanochat-sample.svg
