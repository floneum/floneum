# Runtime-tunable nanochat stroke settings.

NANOCHAT_DATASET_PATH=../feather-pipeline/output-grid9-relaxed-curved-release/icons_clean.json
# When true with a Feather dataset, nanochat appends a matching amount of synthetic data per split.
NANOCHAT_INCLUDE_SYNTHETIC_DATA=true

# The defaults below use the full accepted Feather 9x9 set in under a minute on CPU debug runs.
NANOCHAT_EPOCHS=40
NANOCHAT_WARMUP_STEPS=2
NANOCHAT_LEARNING_RATE=0.003
NANOCHAT_MIN_LEARNING_RATE=3e-4
NANOCHAT_BETA1=0.9
NANOCHAT_BETA2=0.95
NANOCHAT_ADAM_EPS=1e-8
NANOCHAT_WEIGHT_DECAY=0.01
NANOCHAT_LOG_EVERY=20
NANOCHAT_EVAL_BATCHES=1
NANOCHAT_BLOCK_SIZE=128
NANOCHAT_BATCH_SIZE=32
NANOCHAT_N_EMBD=128
NANOCHAT_N_HEAD=4
NANOCHAT_N_KV_HEAD=2
NANOCHAT_N_FF=128
NANOCHAT_N_LAYER=4
NANOCHAT_CONV_KERNEL_SIZE=3
NANOCHAT_ATTENTION_PERIOD=1
NANOCHAT_EPS=1e-5
NANOCHAT_INIT_SCALE=0.1
NANOCHAT_SEED=666
# For Feather datasets, 0 means "use the full split" without truncation.
NANOCHAT_TRAIN_EXAMPLES=0
NANOCHAT_VALID_EXAMPLES=0
NANOCHAT_TEST_EXAMPLES=0
NANOCHAT_SAMPLE_PREFIX_TOKENS=4
NANOCHAT_SAMPLE_TOKENS=64
NANOCHAT_SAMPLE_TEMPERATURE=0.7
NANOCHAT_SAMPLE_TOP_K=2
NANOCHAT_SAVE_EVERY_STEPS=0
NANOCHAT_SAVE_FINAL_MODEL=true
NANOCHAT_SAVE_QUANTIZATION=q4_0
NANOCHAT_GGUF_PATH=nanochat.gguf
NANOCHAT_SAMPLE_OUTPUT_PATH=nanochat-sample.svg
NANOCHAT_USE_ROPE=true
NANOCHAT_ROPE_THETA=10000
NANOCHAT_USE_CANVAS_STATE_EMBEDDINGS=true
NANOCHAT_USE_EXTRA_NORMS=false
